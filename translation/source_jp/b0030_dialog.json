{
"cat": "dialog",
"items": [
{
"i": 0,
"t": "\\nされど、それゆえに支え甲斐もあるもの"
},
{
"i": 1,
"t": "\\nされども手を打っておいたがため\\n害を免れた地がある"
},
{
"i": 2,
"t": "\\nされど従う他"
},
{
"i": 3,
"t": "\\nざまあみろ！"
},
{
"i": 4,
"t": "\\nしかし、そうだな、"
},
{
"i": 5,
"t": "\\nしかし敵は兵糧が足りて"
},
{
"i": 6,
"t": "\\nしかも猛将"
},
{
"i": 7,
"t": "\\nしばし機を待つのが"
},
{
"i": 8,
"t": "\\nしばらくは満足に動けぬ"
},
{
"i": 9,
"t": "\\nしばらくは領地発展に努めつつ\\n周囲の隙をうかが"
},
{
"i": 10,
"t": "\\nしばらく内政に力を置き\\n腰を据えて任地を発展させ"
},
{
"i": 11,
"t": "\\nじっくり腰を据え、まずはこの地で\\n敵と対峙し得る国力を備え"
},
{
"i": 12,
"t": "\\nすぐに交渉に移"
},
{
"i": 13,
"t": "\\nすべて領内を発展させるのに有効ですが、それぞれ特徴があります。\\n勢力の状況に応じてどの手段を用いるか判断しましょう。\\n\\n"
},
{
"i": 14,
"t": "\\nぜひとも成果に"
},
{
"i": 15,
"t": "\\nぜひとも牢人を登用し、ゆくゆくは\\n我が城の郡を治めさせたく…"
},
{
"i": 16,
"t": "\\nそう"
},
{
"i": 17,
"t": "\\nそう来"
},
{
"i": 18,
"t": "\\nそう簡単に渡さんて"
},
{
"i": 19,
"t": "\\nそのため、自由な外交はでき"
},
{
"i": 20,
"t": "\\nそのためのご機嫌伺いなら安いもの"
},
{
"i": 21,
"t": "\\nその上、兵糧も十分とは言え"
},
{
"i": 22,
"t": "\\nその上兵糧には不安が残"
},
{
"i": 23,
"t": "\\nその地に住む者らは難儀"
},
{
"i": 24,
"t": "\\nその後は和を保つか、よくよくお考えを"
},
{
"i": 25,
"t": "\\nその折は色良き"
},
{
"i": 26,
"t": "\\nその程度の家であったか"
},
{
"i": 27,
"t": "\\nそれが貴家の意向とあらば\\nそのとおり受け取らせて"
},
{
"i": 28,
"t": "\\nそれでこそ、俺の背を預けるに値する"
},
{
"i": 29,
"t": "\\nそろそろ帰還するべき"
},
{
"i": 30,
"t": "\\nただ、"
},
{
"i": 31,
"t": "\\nただ、代わりに"
},
{
"i": 32,
"t": "\\nただ、油断は"
},
{
"i": 33,
"t": "\\nただし兵糧には不安が残"
},
{
"i": 34,
"t": "\\nただし兵糧には留意"
},
{
"i": 35,
"t": "\\nついては、工費の援助を願いたく…"
},
{
"i": 36,
"t": "\\nついては一言進言したく…"
},
{
"i": 37,
"t": "\\nであれば落とせましょう\\n指針の変更を願います"
},
{
"i": 38,
"t": "\\nでは、今なすべきことについて\\n"
},
{
"i": 39,
"t": "\\nでは今から城に戻り\\nすぐに土産と共に参りましょう"
},
{
"i": 40,
"t": "\\nでは今から城に戻りますが\\nすぐに土産と共に参りましょう"
},
{
"i": 41,
"t": "\\nでもやっておくか"
},
{
"i": 42,
"t": "\\nともあろう者が…"
},
{
"i": 43,
"t": "\\nどうか"
},
{
"i": 44,
"t": "\\nどうか、"
},
{
"i": 45,
"t": "\\nどうか、お心に留めて"
},
{
"i": 46,
"t": "\\nどうか、ご決断を"
},
{
"i": 47,
"t": "\\nどうか、後は"
},
{
"i": 48,
"t": "\\nどうかうまく働く場を\\n与えて"
},
{
"i": 49,
"t": "\\nどうかご無事で！"
},
{
"i": 50,
"t": "\\nどうか我が軍団に"
},
{
"i": 51,
"t": "\\nどうぞ見返りをお示しあれ"
},
{
"i": 52,
"t": "\\nどうやら些細なことが原因だったようで…\\nこれで領内は元通りにな"
},
{
"i": 53,
"t": "\\nどうやら実行できそうな提案がある様子\\n確認のうえ、決裁して"
},
{
"i": 54,
"t": "\\nどうやら怪我によく効くらしく\\n兵らの養生にも役立つ"
},
{
"i": 55,
"t": "\\nどなたかに郡を与えて\\n発展を任せるのはいかが"
},
{
"i": 56,
"t": "\\nどの城を強化するか、"
},
{
"i": 57,
"t": "\\nどの城主の策を行うか、"
},
{
"i": 58,
"t": "\\nどれ、"
},
{
"i": 59,
"t": "\\nなかなかの痛手"
}
]
