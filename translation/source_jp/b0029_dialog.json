{
"cat": "dialog",
"items": [
{
"i": 0,
"t": "\\nかもしれ"
},
{
"i": 1,
"t": "\\nかわせたな"
},
{
"i": 2,
"t": "\\nが手薄のようだ\\n攻める好機ではあるが…"
},
{
"i": 3,
"t": "\\nくれぐれもお気をつけを…"
},
{
"i": 4,
"t": "\\nくれぐれも注意して"
},
{
"i": 5,
"t": "\\nこうして再度声を掛けられたからには\\n従うほか道はあ"
},
{
"i": 6,
"t": "\\nここは"
},
{
"i": 7,
"t": "\\nここは一つ、"
},
{
"i": 8,
"t": "\\nここは慰撫しては"
},
{
"i": 9,
"t": "\\nここは我が軍団に"
},
{
"i": 10,
"t": "\\nここは手すきの者に統治を任せ\\n我らが本拠の発展に繋げ"
},
{
"i": 11,
"t": "\\nここは撤退させてもら"
},
{
"i": 12,
"t": "\\nここは新たに"
},
{
"i": 13,
"t": "\\nここは貴種たる"
},
{
"i": 14,
"t": "\\nここは退くしか"
},
{
"i": 15,
"t": "\\nこちらからも反撃"
},
{
"i": 16,
"t": "\\nこちらの提案は取り下げ"
},
{
"i": 17,
"t": "\\nことに目標を提言した者らの功績は大きく\\n格別の報奨を与えることと"
},
{
"i": 18,
"t": "\\nこのような品に出会えるとは…"
},
{
"i": 19,
"t": "\\nこのような品をいただけるとは…"
},
{
"i": 20,
"t": "\\nこのような輩、すぐさま流言を信じ\\n主家に愛想を尽かす"
},
{
"i": 21,
"t": "\\nこの先も、互いに切磋琢磨してゆこうぞ"
},
{
"i": 22,
"t": "\\nこの勢いで"
},
{
"i": 23,
"t": "\\nこの勢いで守り抜く！"
},
{
"i": 24,
"t": "\\nこの得意の弁舌で"
},
{
"i": 25,
"t": "\\nこの新しい道を用いることで\\n多方から攻め入ることも叶"
},
{
"i": 26,
"t": "\\nこの機に頂くのも\\n手かと存じます"
},
{
"i": 27,
"t": "\\nこの機を見逃すことなきよう"
},
{
"i": 28,
"t": "\\nこれからも"
},
{
"i": 29,
"t": "\\nこれぐらいはや"
},
{
"i": 30,
"t": "\\nこれしきの劣勢、歯牙にもかけんわ！"
},
{
"i": 31,
"t": "\\nこれで"
},
{
"i": 32,
"t": "\\nこれであれば喜んでお仕えしよう"
},
{
"i": 33,
"t": "\\nこれで人の往来も増え"
},
{
"i": 34,
"t": "\\nこれで多くの駿馬が育ち\\n騎兵も大いに精強となる"
},
{
"i": 35,
"t": "\\nこれで多少の攻撃なら耐えられ"
},
{
"i": 36,
"t": "\\nこれで当家はさらに発展する"
},
{
"i": 37,
"t": "\\nこれで民も安心して暮らせ"
},
{
"i": 38,
"t": "\\nこれならば、いつでも敵を迎え撃て"
},
{
"i": 39,
"t": "\\nこれならば、しばらく\\n兵糧の心配は不要"
},
{
"i": 40,
"t": "\\nこれにて引き上げさせて"
},
{
"i": 41,
"t": "\\nこれに備えて"
},
{
"i": 42,
"t": "\\nこれも"
},
{
"i": 43,
"t": "\\nこれもこの地を治める"
},
{
"i": 44,
"t": "\\nこれもまた縁…"
},
{
"i": 45,
"t": "\\nこれよりは従属でなく対等な同盟を結び\\nともに助け合"
},
{
"i": 46,
"t": "\\nこれよりは従属でなく対等な同盟を結び\\n共に助け合"
},
{
"i": 47,
"t": "\\nこれより忠勤に励"
},
{
"i": 48,
"t": "\\nこれより我が軍団にて\\n"
},
{
"i": 49,
"t": "\\nこれを建てられれば\\n"
},
{
"i": 50,
"t": "\\nこれを捨て置くは"
},
{
"i": 51,
"t": "\\nこれ以上の被害は出ない"
},
{
"i": 52,
"t": "\\nこれ以上は望めない内容にな"
},
{
"i": 53,
"t": "\\nご判断は"
},
{
"i": 54,
"t": "\\nご検討"
},
{
"i": 55,
"t": "\\nご確認"
},
{
"i": 56,
"t": "\\nさすれば攻略実現のための様々な準備を\\n家臣が提案"
},
{
"i": 57,
"t": "\\nさらなる活躍をお約束いた"
},
{
"i": 58,
"t": "\\nさらなる活躍をどうか、ご期待ください"
},
{
"i": 59,
"t": "\\nさらに敵は兵糧が足りて"
}
]
}