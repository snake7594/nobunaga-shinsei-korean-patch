{
"items": [
{"i": 0, "t": "을(를) 습격해\\n그자에게 상처를 입혀 주"},
{"i": 1, "t": "을(를) 발견했습니다\\n처치해 보이겠습니다"},
{"i": 2, "t": "을(를) 믿고 찾아왔다\\n내 부탁, 들어주게"},
{"i": 3, "t": "을(를) 저버렸는가\\n"},
{"i": 4, "t": "을(를) 저버린 거다.\\n우리를 공격해 온다면 당연히 싸움이\\n난다는 거지, 헤헤, 기대되는군"},
{"i": 5, "t": "을(를) 저버리고\\n"},
{"i": 6, "t": "을(를) 저버리고\\n나를 따르다니\\n그대의 활약, 기대하고 있겠네"},
{"i": 7, "t": "을(를) 저버리고\\n우리에게 빌붙으려 하다니…\\n어느 정도의 각오인지 보여 주시지요"},
{"i": 8, "t": "을(를) 저버리고\\n출분한 자가 있는 듯"},
{"i": 9, "t": "을(를) 해산합니다만\\n정말 괜찮으시겠습니까?"},
{"i": 10, "t": "을(를) 치지 않겠나?\\n병사가 적으니, 노릴 만하다"},
{"i": 11, "t": "을(를) 치면\\n공성전도 수월해질 것이오"},
{"i": 12, "t": "을(를) 토벌하여\\n내 무예의 영예로 삼으리!"},
{"i": 13, "t": "을(를) 치다니\\n제법이군…"},
{"i": 14, "t": "을(를) 칠 호기\\n…라는 것인가"},
{"i": 15, "t": "을(를) 쳐라\\n"},
{"i": 16, "t": "을(를) 쳐라!\\n우리의 공으로 삼으리"},
{"i": 17, "t": "을(를) 이리 평가해 주시다니!\\n이만큼이면 충분하옵니다"},
{"i": 18, "t": "을(를) 평정에…\\n주군은 무슨 생각이신가"},
{"i": 19, "t": "을(를) 인정하지 못할\\n작은 그릇이 아니다"},
{"i": 20, "t": "을(를) 꾀어내고자 적지로 향하던 도중\\n적의 습격을 받아"},
{"i": 21, "t": "을(를) 설득하여\\n당가로 끌어들여 보이"},
{"i": 22, "t": "을(를) 설득하여\\n아군으로 삼을 수 있다면…"},
{"i": 23, "t": "을(를) 경계하여\\n간자를 몰아내리"},
{"i": 24, "t": "을(를) 사들였습니다\\n금"},
{"i": 25, "t": "을(를) 맞아 싸우는 것이 아니라\\n"},
{"i": 26, "t": "을(를) 돌려달라니…\\n마음대로 해"},
{"i": 27, "t": "을(를) 돌려달라, 즉\\n그런 뜻"},
{"i": 28, "t": "을(를) 쫓아내 버리면\\n"},
{"i": 29, "t": "을(를) 쫓아내면\\n"},
{"i": 30, "t": "을(를) 돌려보낸 일\\n후회하는 일이 없어야 할 텐데 말이오"},
{"i": 31, "t": "을(를) 돌려보내다니 배짱 한번 좋군\\n좋아, 그럴 셈이라면\\n이쪽도 생각이 있다 이거다!"},
{"i": 32, "t": "을(를) 추방하면\\n"},
{"i": 33, "t": "을(를) 추방하다니\\n어지간히 미움받았나 보군요…"},
{"i": 34, "t": "을(를) 추방하다니\\n아무것도 모르는군…"},
{"i": 35, "t": "을(를) 추방?\\n"},
{"i": 36, "t": "을(를) 물리친 날에는\\n주군의 무명도\\n천하에 널리 울려 퍼질 것입니다"},
{"i": 37, "t": "을(를) 놓치면\\n대대로 이어질 수치이니라"},
{"i": 38, "t": "을(를) 놓치지 마라\\n숨통을 끊는 것이다!"},
{"i": 39, "t": "을(를) 진행하여\\n다음에 대비하시는 것이 어떻겠습니까"},
{"i": 40, "t": "을(를) 진행하고자 하니\\n허가를 청하옵니다"},
{"i": 41, "t": "을(를) 진행하고 왔사옵니다\\n주군의 뜻에 모두가 감읍하는 지경\\n다음부터는 거의 전원이 당가에 참진할 듯하옵니다"},
{"i": 42, "t": "을(를) 진행할 허가를\\n내려 주시길 바라옵니다"},
{"i": 43, "t": "을(를) 진행하면\\n"},
{"i": 44, "t": "을(를) 피하는 것도\\n무례라는 것인가…"},
{"i": 45, "t": "을(를) 배치하면\\n영주 부재 기간을\\n최단으로 줄일 수 있어"},
{"i": 46, "t": "을(를) 배속하여\\n정무 공헌을 지시하고"},
{"i": 47, "t": "을(를) 배속해도\\n손해는 없을 것으로"},
{"i": 48, "t": "을(를) 배속하면\\n부대의 방비 강화에 공헌할 수 있을 듯합니다"},
{"i": 49, "t": "을(를) 배속할 때는\\n거리가 멀어, 부임에 시간이 걸릴 듯…"},
{"i": 50, "t": "을(를) 간자로부터\\n지켜내"},
{"i": 51, "t": "을(를) 방어하라\\n지켜내는 게야!"},
{"i": 52, "t": "을(를) 저지하고\\n"},
{"i": 53, "t": "을(를) 항복시키고\\n"},
{"i": 54, "t": "을(를) 함락했도다!\\n우리"},
{"i": 55, "t": "을(를) 떠난다\\n"},
{"i": 56, "t": "을(를) 주신다고 하셔도\\n"},
{"i": 57, "t": "을(를) 받는 것은 기쁩니다만\\n"},
{"i": 58, "t": "을(를) 맡을 수 있다면\\n영지에 관한 불만 따위\\n품을 리가"},
{"i": 59, "t": "을(를) 부탁하겠네만\\n과연, 옳은 판단인가"}
]
}
