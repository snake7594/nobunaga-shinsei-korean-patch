{
"items": [
{"i": 0, "t": "적은 소수입니다\\n공격만으로 이길 수 있습니다"},
{"i": 1, "t": "적은 약해져 있다\\n짓밟아 버려라!"},
{"i": 2, "t": "적은 약졸!\\n공격할 때입니다!"},
{"i": 3, "t": "적이 겁먹었다\\n밀어붙여라!"},
{"i": 4, "t": "적이 겁먹고 있다\\n공격할 때다!"},
{"i": 5, "t": "적은 전의를 잃고 철수할 모양…\\n이 싸움,"},
{"i": 6, "t": "적은 협격이 노림수인가\\n"},
{"i": 7, "t": "적은 협격할 셈인가?\\n"},
{"i": 8, "t": "적은 협격을 꾀하고 있습니다\\n요격 부대를 파견합시다"},
{"i": 9, "t": "적은 협격을 노리는 모양\\n발을 묶는 것이 상책일 것입니다"},
{"i": 10, "t": "적은 제거했다\\n"},
{"i": 11, "t": "적은 격퇴했군\\n"},
{"i": 12, "t": "적은 이미 없다\\n성으로 돌아간다"},
{"i": 13, "t": "적은 오합지졸\\n짓밟아 버리고 오너라!"},
{"i": 14, "t": "적은 가이의 호랑이인가…\\n무, 무사의 전율이 멎지 않는구나"},
{"i": 15, "t": "적이 가이의 호랑이라 해도\\n"},
{"i": 16, "t": "적은 요소를 노리고 있군\\n부대를 나누어 대비해야 할 듯합니다"},
{"i": 17, "t": "적은 마음껏 쳐도 좋다!\\n사양은 필요 없다!"},
{"i": 18, "t": "적은 쫓아냈다!\\n"},
{"i": 19, "t": "적은 퇴로로 향하는 모양\\n우리도 맞서 싸워야 할 듯합니다"},
{"i": 20, "t": "적은 퇴로를 찌를 셈인 듯합니다!\\n아군에게 지키게 해야 합니다"},
{"i": 21, "t": "적은 몰아냈다\\n"},
{"i": 22, "t": "적은 마왕인가\\n…이 일전으로 아버지를 뛰어넘어 보이겠다!"},
{"i": 23, "t": "적에 대한 대비는 맹장에게 맡기고 싶은 법\\n「"},
{"i": 24, "t": "적에 대응하기엔 전력이 미덥지 못하여…\\n"},
{"i": 25, "t": "적도\\n제법이군요"},
{"i": 26, "t": "적도 우리의 정예로움에 놀랐을 것이다"},
{"i": 27, "t": "적도 만만치 않군\\n두더지 공격을 알아채고 막다니\\n다음 수를 생각합시다"},
{"i": 28, "t": "적도 같은 인간\\n생각하면 답은 나옵니다"},
{"i": 29, "t": "적도 아군도, 괄목하라!\\n이 독안룡의 웅비를 지켜보아라!"},
{"i": 30, "t": "적도 아군에게\\n두려움을 느꼈을 것이다"},
{"i": 31, "t": "적도 아군의 강함을\\n뼈저리게 알았으리라!"},
{"i": 32, "t": "적도 수단을 가릴\\n처지가 아닌 모양…"},
{"i": 33, "t": "적도 부대를 내보내는 일이 있으니,\\n전투가 벌어져도 이길 수 있도록\\n전력을 갖춘 뒤에 공격하는 것이 좋습니다"},
{"i": 34, "t": "적보다 적다…\\n지키는 편이 좋겠네요"},
{"i": 35, "t": "적보다 소수인가…\\n퇴로의 수비를 맡겠다"},
{"i": 36, "t": "적을 속이는 것도\\n재미있구먼!"},
{"i": 37, "t": "적을 쓰러뜨릴 방법이야\\n얼마든지 있지"},
{"i": 38, "t": "적을 압도할 계책을\\n생각해야겠군"},
{"i": 39, "t": "적을 맨손으로 사로잡다니\\n호걸이로군,"},
{"i": 40, "t": "적을 저지하라!\\n요소는 내줄 수 없으니"},
{"i": 41, "t": "적을 포착했습니다!\\n공격 개시!"},
{"i": 42, "t": "적을 격파!\\n다음은"},
{"i": 43, "t": "적을 막아라!\\n요소에 접근하게 두지 마라"},
{"i": 44, "t": "적을 농락할 방책이라면\\n무수히 갖고 있다"},
{"i": 45, "t": "적을 보내지 마라!\\n협격을 저지하는 것이다"},
{"i": 46, "t": "적을 쳐라!\\n무공을 떨치는 것이다!"},
{"i": 47, "t": "적을 요격하겠습니다\\n요지에는 접근하지 못하게 하겠습니다"},
{"i": 48, "t": "적을 놓치지 마라!\\n소탕하라!"},
{"i": 49, "t": "적을 통과시키지 마라!\\n요소는 내주지 않는다!"},
{"i": 50, "t": "적 병력은 새 발의 피\\n자, 돌격이다!"},
{"i": 51, "t": "적병!?\\n여기는 물러설 수밖에…"},
{"i": 52, "t": "적전 도주라는 대죄를 저지르고도,\\n<ESC>CA히데요시<ESC>CZ는 <ESC>CA노부나가<ESC>CZ에게 거의 처벌을 받지 않았고,\\n오히려 <ESC>CC주고쿠<ESC>CZ 경략의 대임을 맡았다."},
{"i": 53, "t": "적전 도주는 사죄에 해당한다!\\n원숭이, 무슨 변명이라도 있느냐?"},
{"i": 54, "t": "적군을 쳐부수었다!\\n이 가메와리"},
{"i": 55, "t": "적군을 쳐부수었다!\\n가메와리"},
{"i": 56, "t": "적군이 요소로 향하고 있습니다\\n누군가에게 수비를 맡깁시다"},
{"i": 57, "t": "적군이라니!?\\n우리도 물러난다"},
{"i": 58, "t": "적군과 일전을 치르더라도,\\n먼저 이 땅을 제압해야 할 듯합니다"},
{"i": 59, "t": "적군을 협격한다!\\n신속히 이동하라"}
]
