{
"items": [
{"i": 0, "t": "이토록 가신의 불만을\\n방치하시다니"},
{"i": 1, "t": "이리도 쉽게\\n등을 보이다니"},
{"i": 2, "t": "이렇게 줄어들어서는…\\n어쩔 수 없다, 철수하겠소"},
{"i": 3, "t": "이리 간단히 당하다니…!\\n"},
{"i": 4, "t": "이리도 얕보이니\\n서글퍼지는구려"},
{"i": 5, "t": "이리 몰리다니\\n…큭, 물러나라"},
{"i": 6, "t": "이리 오래 살았으니 여한 따위…\\n산더미처럼 있다만, 후진에게 맡기기로 할까…"},
{"i": 7, "t": "이렇게 쓰는 것이군요\\n알고 있었습니다"},
{"i": 8, "t": "이리 병사가 줄어서야…\\n퇴로의 수비를 맡을까"},
{"i": 9, "t": "이리 사격의 기세가 강해서야…\\n고지를 빼앗을 부대를 보내야 할 듯합니다"},
{"i": 10, "t": "이리 밀려서는…\\n모두들, 철수해 주십시오!"},
{"i": 11, "t": "이리 총격을 받아서야…\\n후퇴해야 할 것이다"},
{"i": 12, "t": "이리 총격을 받아서는 나아갈 수 없다\\n일단 물러날까…"},
{"i": 13, "t": "이리 더워서야\\n의욕이 나지 않는군요…"},
{"i": 14, "t": "이리 몰려서는…\\n철수다!　모두, 살아서 돌아가라!"},
{"i": 15, "t": "여기서부터\\n흐름을 바꿔 보자!"},
{"i": 16, "t": "여기서부터는, 이\\n"},
{"i": 17, "t": "여기가 저의 끝입니까…\\n힘닿는 데까지 다했다고 여겼습니다만…"},
{"i": 18, "t": "여기가 승부처!\\n모두, 단념하거라!"},
{"i": 19, "t": "여기가 승부의\\n갈림길이다!"},
{"i": 20, "t": "여기가 내 집…\\n같은 기분마저 드는군"},
{"i": 21, "t": "여기가 고비입니다\\n마음을 다잡고 갑시다"},
{"i": 22, "t": "여기가 고비다!\\n요충지는 내주지 않겠다!"},
{"i": 23, "t": "지금이 물러날 때…\\n물러나겠습니다!"},
{"i": 24, "t": "이 정도 요구는 해도\\n상대가 싫은 내색은 하지 않을 것입니다"},
{"i": 25, "t": "여기서\\n공격해 오다니…"},
{"i": 26, "t": "여기서\\n끝장을 냅시다!"},
{"i": 27, "t": "여기서 더 시간을 허비하기는 아깝다.\\n외교로 공세를 펼칠까…"},
{"i": 28, "t": "여기서 잠시\\n휴식을 취하게 하자"},
{"i": 29, "t": "여기서 막아라!\\n요충지에 접근하게 두지 마라!"},
{"i": 30, "t": "여기서는 지킬 수 없다\\n장소를 옮기겠다"},
{"i": 31, "t": "여기서는 대응하기 어렵다\\n방어에 좋은 위치로 가자"},
{"i": 32, "t": "여기서는 싸움에 낄 수 없다\\n원호할 수 있는 곳으로 나간다!"},
{"i": 33, "t": "여기서는 원호하기 어렵다\\n이동하겠다"},
{"i": 34, "t": "여기서는 원호할 수 없습니다\\n더 앞으로 나갑시다!"},
{"i": 35, "t": "여기서는 원호할 수 없습니다\\n좀 더 앞으로 나가도록 하지요"},
{"i": 36, "t": "여기서는 지원할 수 없다\\n우리도 앞으로 나간다"},
{"i": 37, "t": "여기서는 지원할 수 없다\\n좀 더 가까이 가도록 하지"},
{"i": 38, "t": "여기서는 지원할 수 없습니다\\n우리는 전진하겠습니다"},
{"i": 39, "t": "여기서는 지원할 수 없겠군요\\n장소를 바꿉시다"},
{"i": 40, "t": "여기서는 지원이 안 된다\\n앞으로 나간다"},
{"i": 41, "t": "여기서는 과녁이 된다\\n후방으로 물러나기로 하자"},
{"i": 42, "t": "여기서는 너무 멀군\\n지원할 수 있는 위치로 가자"},
{"i": 43, "t": "여기서 느긋하게\\n기다리기로 하자"},
{"i": 44, "t": "원수는 외나무다리에서 만난다더니\\n"},
{"i": 45, "t": "이쯤에서 쓰러뜨려\\n두고 싶군요"},
{"i": 46, "t": "여기서 용맹을 떨친 것이 <ESC>CA가쓰이에<ESC>CZ의 조카로\\n「오니겐바」라 불리는 맹장,\\n<ESC>CA사쿠마 모리마사<ESC>CZ이다."},
{"i": 47, "t": "여기서 화친으로 물러나는가, 지난날의 힘은\\n<ESC>CB우에스기<ESC>CZ에게 없다고 보았다, 두려워할 것 없느니라."},
{"i": 48, "t": "여기서 대기하겠습니다\\n지나가는 적에게 활을 쏘시오"},
{"i": 49, "t": "여기서 대기하겠습니다\\n지나가는 적에게 총을 쏘시오"},
{"i": 50, "t": "여기서 대기한다\\n활로 요격한다"},
{"i": 51, "t": "여기서 대기한다\\n철포로 요격한다"},
{"i": 52, "t": "여기서 대기하라!\\n적이 보이는 대로 활을 쏴라!"},
{"i": 53, "t": "여기서 대기하라!\\n적이 보이는 대로 총을 쏴라!"},
{"i": 54, "t": "여기서 대기다\\n적이 오면 활을 쏘는 것이다"},
{"i": 55, "t": "여기서 대기다\\n적이 오면 총을 쏘는 것이다"},
{"i": 56, "t": "여기서 원군이…?\\n우리의 소모가 노림수인가"},
{"i": 57, "t": "여기서 원군인가\\n흠, 예상대로다"},
{"i": 58, "t": "여기서 절연이라는 한 수, 묘수이다만\\n"},
{"i": 59, "t": "여기서 협격이라니!?\\n악수를 두었단 말인가…!"}
]
}
