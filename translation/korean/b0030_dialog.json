{
"items": [
{"i": 0, "t": "\\n허나 그렇기에 보필할 보람도 있는 법"},
{"i": 1, "t": "\\n허나 미리 손을 써 둔 덕에\\n해를 면한 땅이 있소"},
{"i": 2, "t": "\\n허나 따르는 수밖에"},
{"i": 3, "t": "\\n꼴좋다!"},
{"i": 4, "t": "\\n허나, 그렇군,"},
{"i": 5, "t": "\\n허나 적은 병량이 넉넉하여"},
{"i": 6, "t": "\\n게다가 맹장"},
{"i": 7, "t": "\\n잠시 때를 기다리는 것이"},
{"i": 8, "t": "\\n당분간은 제대로 움직이지 못하리라"},
{"i": 9, "t": "\\n당분간은 영지 발전에 힘쓰며\\n주위의 틈을 엿보"},
{"i": 10, "t": "\\n당분간 내정에 힘을 쏟아\\n진득하게 임지를 발전시키"},
{"i": 11, "t": "\\n차분히 자리를 잡고, 우선 이 땅에서\\n적과 맞설 국력을 갖추"},
{"i": 12, "t": "\\n곧바로 교섭에 들어가"},
{"i": 13, "t": "\\n모두 영내를 발전시키는 데 유효하나 저마다 특징이 있습니다.\\n세력의 상황에 따라 어느 수단을 쓸지 판단하십시오.\\n\\n"},
{"i": 14, "t": "\\n부디 성과로"},
{"i": 15, "t": "\\n부디 낭인을 등용하여 장차\\n우리 성의 군을 다스리게 하고자…"},
{"i": 16, "t": "\\n그리"},
{"i": 17, "t": "\\n그렇게 나오"},
{"i": 18, "t": "\\n그리 쉽게 넘겨줄 성싶으냐"},
{"i": 19, "t": "\\n그 때문에 자유로운 외교는 하지 못하"},
{"i": 20, "t": "\\n그를 위한 비위 맞추기라면 값싼 것"},
{"i": 21, "t": "\\n게다가 병량도 충분하다고는 할 수 없"},
{"i": 22, "t": "\\n게다가 병량에는 불안이 남"},
{"i": 23, "t": "\\n그 땅에 사는 자들은 고초를 겪"},
{"i": 24, "t": "\\n그 후에는 화친을 유지할지, 깊이 생각해 보시오"},
{"i": 25, "t": "\\n그때는 좋은"},
{"i": 26, "t": "\\n그 정도밖에 안 되는 가문이었나"},
{"i": 27, "t": "\\n그것이 귀가의 뜻이라면\\n그대로 받아들이"},
{"i": 28, "t": "\\n그래야말로 내 등을 맡길 만하지"},
{"i": 29, "t": "\\n슬슬 귀환해야 할"},
{"i": 30, "t": "\\n다만,"},
{"i": 31, "t": "\\n다만, 그 대신"},
{"i": 32, "t": "\\n다만, 방심은"},
{"i": 33, "t": "\\n다만 병량에는 불안이 남"},
{"i": 34, "t": "\\n다만 병량에는 유의"},
{"i": 35, "t": "\\n하여, 공사 비용의 원조를 청하고자…"},
{"i": 36, "t": "\\n하여 한 말씀 진언드리고자…"},
{"i": 37, "t": "\\n그렇다면 함락시킬 수 있을 것입니다\\n지침의 변경을 청하옵니다"},
{"i": 38, "t": "\\n그럼, 지금 해야 할 일에 대해\\n"},
{"i": 39, "t": "\\n그럼 지금 성으로 돌아가\\n곧 예물과 함께 찾아뵙겠습니다"},
{"i": 40, "t": "\\n그럼 지금 성으로 돌아가되\\n곧 예물과 함께 찾아뵙겠습니다"},
{"i": 41, "t": "\\n그래도 해 둘까"},
{"i": 42, "t": "\\n쯤 되는 자가…"},
{"i": 43, "t": "\\n부디"},
{"i": 44, "t": "\\n부디,"},
{"i": 45, "t": "\\n부디, 마음에 새겨"},
{"i": 46, "t": "\\n부디, 결단을"},
{"i": 47, "t": "\\n부디, 뒷일은"},
{"i": 48, "t": "\\n부디 제대로 일할 자리를\\n마련해"},
{"i": 49, "t": "\\n부디 무사하시길!"},
{"i": 50, "t": "\\n부디 우리 군단에"},
{"i": 51, "t": "\\n부디 보답을 제시해 주시오"},
{"i": 52, "t": "\\n아무래도 사소한 일이 원인이었던 듯…\\n이로써 영내는 원래대로 돌아가"},
{"i": 53, "t": "\\n아무래도 실행할 만한 제안이 있는 모양\\n확인한 뒤 결재해"},
{"i": 54, "t": "\\n아무래도 상처에 잘 듣는다 하니\\n병사들의 요양에도 도움이 될 것"},
{"i": 55, "t": "\\n누군가에게 군을 내려\\n발전을 맡기는 것은 어떠하신지"},
{"i": 56, "t": "\\n어느 성을 강화할지,"},
{"i": 57, "t": "\\n어느 성주의 책략을 행할지,"},
{"i": 58, "t": "\\n어디,"},
{"i": 59, "t": "\\n꽤나 뼈아픈 타격"}
]
}
