{
"items": [
{"i": 0, "t": "이(가)\\n병량을 부과해서는"},
{"i": 1, "t": "이(가)\\n겸임하여"},
{"i": 2, "t": "이(가)\\n나타났습니다, 붙잡읍시다"},
{"i": 3, "t": "이(가)\\n전선에서 멀어 불편"},
{"i": 4, "t": "이(가)\\n공을 세울 차례입니다"},
{"i": 5, "t": "이(가)\\n가세하면 백인력입니다"},
{"i": 6, "t": "이(가)\\n효과는 절대적이라 할 수"},
{"i": 7, "t": "이(가)\\n이기기를 믿어 보자"},
{"i": 8, "t": "이(가)\\n이기면 좋겠군"},
{"i": 9, "t": "이(가)\\n이기면 좋겠구먼…"},
{"i": 10, "t": "이(가)\\n점령했다!"},
{"i": 11, "t": "이(가)\\n참집하시다니"},
{"i": 12, "t": "이(가)\\n중개역 부재라니"},
{"i": 13, "t": "이(가)\\n주변 세력에게 불신을 사고 있어"},
{"i": 14, "t": "이(가)\\n성하 시설을 지은 보람이 있어\\n일부 지역은 화를 면한 듯"},
{"i": 15, "t": "이(가)\\n성하 시설을 지은 보람이 있어\\n일부 군은 화를 면한 듯"},
{"i": 16, "t": "이(가)\\n착실히 진행할 수 있어"},
{"i": 17, "t": "이(가)\\n큰 효과를 기대할 수 있을 것입니다"},
{"i": 18, "t": "이(가)\\n별것 아니다"},
{"i": 19, "t": "이(가)\\n위신에 압도되어 병사가 위축되어"},
{"i": 20, "t": "이(가)\\n혼인이라니 참으로 경사로군\\n이걸로 두 가문은 한식구란 말이지!"},
{"i": 21, "t": "이(가)\\n실행할 수 있을 만한 제안은"},
{"i": 22, "t": "이(가)\\n무너질 줄이야…"},
{"i": 23, "t": "이(가)\\n물러날 때도 생각해 두셔야 할 듯합니다"},
{"i": 24, "t": "이(가)\\n강한 불만을 품고 있습니다\\n회유하면 귀순할지도 모릅니다"},
{"i": 25, "t": "이(가)\\n강하게 불만을 토로한다 합니다\\n조략을 걸 때인지도 모릅니다"},
{"i": 26, "t": "이(가)\\n당주라니"},
{"i": 27, "t": "이(가)\\n당가를 섬기고 싶다 합니다\\n준비를 갖추어"},
{"i": 28, "t": "이(가)\\n당가에 종속하도록 요구하여"},
{"i": 29, "t": "이(가)\\n당가에 신종하고 싶다 청하여"},
{"i": 30, "t": "이(가)\\n당가의 산하에서 이탈했습니다.\\n미덥지 못하다 여긴 것일까요…"},
{"i": 31, "t": "이(가)\\n당가로 돌아설지도 모른다고…"},
{"i": 32, "t": "이(가)\\n필요에 따라 거래에 쓰는 것도 한 방법일 듯합니다"},
{"i": 33, "t": "이(가)\\n내 계산대로 움직여 준다면…"},
{"i": 34, "t": "이(가)\\n싸움을 걸어올지도 모릅니다.\\n병량과 병마의 대비는 충분하신지요"},
{"i": 35, "t": "이(가)\\n전황은 당가가 우세하다 보고"},
{"i": 36, "t": "이(가)\\n관계 단절 같은 짓을 저지르다니.\\n이를 내버려 두면 후환이 될 것입니다"},
{"i": 37, "t": "이(가)\\n공을 세워 보이겠다"},
{"i": 38, "t": "이(가)\\n공을 세울 차례로군요"},
{"i": 39, "t": "이(가)\\n승낙하시겠습니까?"},
{"i": 40, "t": "이(가)\\n밀리고 말 줄이야…"},
{"i": 41, "t": "이(가)\\n쳐들어올 것 같습니다"},
{"i": 42, "t": "이(가)\\n공격받으면 도와주는 거지?\\n짐만 되지 않으면 좋겠는데 말이야"},
{"i": 43, "t": "이(가)\\n정책이 주효하여\\n일부 지역은 화를 면한 듯"},
{"i": 44, "t": "이(가)\\n정책이 주효하여\\n일부 군은 화를 면한 듯"},
{"i": 45, "t": "이(가)\\n패할 줄이야…"},
{"i": 46, "t": "이(가)\\n패하더라도 방책은 있다…"},
{"i": 47, "t": "이(가)\\n적장을 사로잡아"},
{"i": 48, "t": "이(가)\\n적 쪽에 이름난 장수는"},
{"i": 49, "t": "이(가)\\n적 본거"},
{"i": 50, "t": "이(가)\\n시간을 들이면 반드시\\n눈 녹는 날이 찾아올 것"},
{"i": 51, "t": "이(가)\\n가장 믿음직한 것은"},
{"i": 52, "t": "이(가)\\n유효하게 활용하고 싶은 동맹"},
{"i": 53, "t": "이(가)\\n유효하게 활용하고 싶은 다이묘"},
{"i": 54, "t": "이(가)\\n바람직한 것은 분명하겠지요"},
{"i": 55, "t": "이(가)\\n기대를 받는 것은 기쁜 법"},
{"i": 56, "t": "이(가)\\n과연 무슨 짓을 해 올지…\\n항상 주의를 기울이셔야 할 듯합니다"},
{"i": 57, "t": "이(가)\\n막아야만 하겠군"},
{"i": 58, "t": "이(가)\\n이번"},
{"i": 59, "t": "이(가)\\n이번 싸움에서 승기는 멀어\\n철수할 때인 듯합니다"}
]
}
