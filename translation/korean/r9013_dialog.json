{"items":[{"i":0,"t":"후방이 불안하구나…\\n물러나야겠다"},{"i":1,"t":"후방이 위태롭다고…?\\n물러나겠소"},{"i":2,"t":"후방이 걱정되기\\n시작하셨겠지요?"},{"i":3,"t":"후방에선 아무것도 못 한다\\n곧장 참전할 곳으로 갈까"},{"i":4,"t":"후방에 있으면 비웃음을 산다\\n전선 가까이로 움직여야겠다"},{"i":5,"t":"후방에서 백성을 섬김이 내 본분\\n부디 영주로 명해 주시오"},{"i":6,"t":"후방의 땅이야말로 내 바람이나\\n…허나,"},{"i":7,"t":"후방을 살피라 하니…\\n과연 일리가 있구나"},{"i":8,"t":"후방 성에서 정무에 힘써\\n내 본령을 보여야 한다"},{"i":9,"t":"후방 성에서 정무에\\n전념해 보고 싶구나…"},{"i":10,"t":"후계자인 <ESC>CA하치로<ESC>CZ는 아직 어리니,\\n여기서 쓰러지면 <ESC>CA나오이에<ESC>CZ가 한 대에 쌓아 올린\\n<ESC>CB우키타<ESC>CZ 가문의 신상도 어찌 될지 알 수 없다…"},{"i":11,"t":"후계자가 군단장이었기에\\n군단을 해산하고 다이묘 직할로 합니다\\n괜찮으십니까?"},{"i":12,"t":"후계자의 죽음으로,\\n정무에 대한 의욕을 잃는 다이묘는 결코 적지 않다."},{"i":13,"t":"후원군이 있었더냐\\n한꺼번에 오면 될 것을"},{"i":14,"t":"후원군이 있었더냐…\\n험한 싸움이 되겠구나…"},{"i":15,"t":"후원군이 오려는가\\n시간을 지체할 수 없다"},{"i":16,"t":"후원군이 온다면\\n어서 함락해야 위험하지 않다"},{"i":17,"t":"후원군이 오기 전에\\n성을 떨어뜨리고 싶구나"},{"i":18,"t":"후원군이 닿기 전에\\n떨어뜨려 버리는 게다"},{"i":19,"t":"후원군이 다가온다\\n어서 함락하지 않으면 위험하다"},{"i":20,"t":"후원군이라고?\\n도착 전에 떨어뜨리자!"},{"i":21,"t":"후원군이라니 성가시다\\n성을 서둘러 떨어뜨려야 한다"},{"i":22,"t":"후원군이라니 가소롭다\\n누가 오든 매한가지다"},{"i":23,"t":"후원군 병력도 대기하고 있다\\n강공으로 떨어뜨려야 한다!"},{"i":24,"t":"후원군 병력도 대기하고 있다\\n손해를 두려워 말고 힘으로 쳐라"},{"i":25,"t":"후원군 병력도 대기하고 있다\\n힘으로 눌러 버리는 게다"},{"i":26,"t":"후원군이 도착하기 전에\\n함락하고 싶군요"},{"i":27,"t":"후원군이 도착하기 전에\\n떨어뜨리면 됩니다"},{"i":28,"t":"후원군도 있다\\n강공으로 빼앗아라!"},{"i":29,"t":"후원군도 있는 것이다\\n두려워 말고 공격해야 한다"},{"i":30,"t":"후원군을 고려한다면\\n힘으로 밀어붙임이 유효하지요"},{"i":31,"t":"후원군을 내보냈더냐\\n어서 끝내야겠다"},{"i":32,"t":"후원군을 내보냈구나\\n침공을 서두르게 하라"},{"i":33,"t":"후원군을 내보냈다면\\n느긋하게 공격할 순 없구나"},{"i":34,"t":"후원군을 서둘러라!\\n병사들이 한계다!"},{"i":35,"t":"후원군을 살리려면\\n힘으로 밀어붙임이 낫다!"},{"i":36,"t":"물러나겠다…\\n내 힘에 부치는 적이었다"},{"i":37,"t":"후진에게 길을 양보한다…\\n그 또한 용기가 아닐는지"},{"i":38,"t":"따르겠다면 거절할 수 없지\\n좋아,"},{"i":39,"t":"따르겠다 하신다면 받아들이겠소\\n"}]}