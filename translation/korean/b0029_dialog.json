{
"items": [
{"i": 0, "t": "\\n일지도 모르"},
{"i": 1, "t": "\\n잘 피했구나"},
{"i": 2, "t": "\\n의 수비가 허술한 듯하다\\n공격할 호기이기는 하나…"},
{"i": 3, "t": "\\n부디 조심하시기를…"},
{"i": 4, "t": "\\n부디 주의하도록"},
{"i": 5, "t": "\\n이렇게 다시 청을 받은 이상\\n따르는 것 외에 길은 없"},
{"i": 6, "t": "\\n이곳은"},
{"i": 7, "t": "\\n여기서 한번,"},
{"i": 8, "t": "\\n여기서는 위무하는 것이"},
{"i": 9, "t": "\\n이곳은 우리 군단에"},
{"i": 10, "t": "\\n이곳은 손이 빈 자에게 통치를 맡기고\\n우리 본거지의 발전으로 이어가"},
{"i": 11, "t": "\\n여기서는 철수하도록 하"},
{"i": 12, "t": "\\n이곳은 새로이"},
{"i": 13, "t": "\\n이곳은 귀한 혈통이신"},
{"i": 14, "t": "\\n여기서는 물러날 수밖에"},
{"i": 15, "t": "\\n이쪽에서도 반격"},
{"i": 16, "t": "\\n이쪽의 제안은 철회하"},
{"i": 17, "t": "\\n특히 목표를 제언한 자들의 공적이 크니\\n각별한 보상을 내리기로"},
{"i": 18, "t": "\\n이런 물건을 만나게 되다니…"},
{"i": 19, "t": "\\n이런 물건을 받게 되다니…"},
{"i": 20, "t": "\\n이런 무리는 금세 유언비어를 믿고\\n주가를 저버리"},
{"i": 21, "t": "\\n앞으로도 서로 절차탁마해 나가세"},
{"i": 22, "t": "\\n이 기세로"},
{"i": 23, "t": "\\n이 기세로 지켜내겠다!"},
{"i": 24, "t": "\\n특기인 이 언변으로"},
{"i": 25, "t": "\\n이 새 길을 이용하면\\n여러 방면에서 공격해 들어갈 수도 있"},
{"i": 26, "t": "\\n이 기회에 취하는 것도\\n방법인가 하옵니다"},
{"i": 27, "t": "\\n이 기회를 놓치는 일이 없도록"},
{"i": 28, "t": "\\n앞으로도"},
{"i": 29, "t": "\\n이 정도는 해"},
{"i": 30, "t": "\\n이만한 열세, 개의치도 않는다!"},
{"i": 31, "t": "\\n이것으로"},
{"i": 32, "t": "\\n이거라면 기꺼이 섬기겠다"},
{"i": 33, "t": "\\n이것으로 사람의 왕래도 늘어"},
{"i": 34, "t": "\\n이것으로 많은 준마가 자라나\\n기병도 크게 강해질 것이다"},
{"i": 35, "t": "\\n이것으로 어지간한 공격은 견딜 수 있"},
{"i": 36, "t": "\\n이것으로 당가는 더욱 발전할 것이다"},
{"i": 37, "t": "\\n이것으로 백성도 안심하고 살 수 있"},
{"i": 38, "t": "\\n이거라면 언제든 적을 맞아 싸울 수 있"},
{"i": 39, "t": "\\n이거라면 당분간\\n병량 걱정은 필요 없"},
{"i": 40, "t": "\\n이만 물러가도록 하"},
{"i": 41, "t": "\\n이에 대비하여"},
{"i": 42, "t": "\\n이것도"},
{"i": 43, "t": "\\n이것도 이 땅을 다스리는"},
{"i": 44, "t": "\\n이것도 또한 인연…"},
{"i": 45, "t": "\\n이제부터는 종속이 아닌 대등한 동맹을 맺어\\n함께 서로 도우"},
{"i": 46, "t": "\\n이제부터는 종속이 아닌 대등한 동맹을 맺어\\n함께 서로 도우"},
{"i": 47, "t": "\\n앞으로 충근에 힘쓰"},
{"i": 48, "t": "\\n앞으로 우리 군단에서\\n"},
{"i": 49, "t": "\\n이것을 세울 수 있다면\\n"},
{"i": 50, "t": "\\n이것을 방치하는 것은"},
{"i": 51, "t": "\\n더 이상의 피해는 나오지 않는다"},
{"i": 52, "t": "\\n더 바랄 수 없는 내용이 되"},
{"i": 53, "t": "\\n판단은"},
{"i": 54, "t": "\\n검토"},
{"i": 55, "t": "\\n확인"},
{"i": 56, "t": "\\n그리하면 공략 실현을 위한 갖가지 준비를\\n가신이 제안"},
{"i": 57, "t": "\\n더 큰 활약을 약속드리"},
{"i": 58, "t": "\\n더 큰 활약을 부디 기대해 주십시오"},
{"i": 59, "t": "\\n게다가 적은 병량이 부족하"}
]
}
