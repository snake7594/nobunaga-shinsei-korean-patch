{
"cat": "dialog",
"items": [
{
"i": 0,
"t": "\\n가문을 위해 전선에서 진력하"
},
{
"i": 1,
"t": "\\n가문을 위해 후방에서 진력하"
},
{
"i": 2,
"t": "\\n가문의 병력과 아군의 전력이\\n충분하다고는 하기 어렵"
},
{
"i": 3,
"t": "\\n가문의 위신이 부족하여\\n추임해 주실 것 같지 않"
},
{
"i": 4,
"t": "\\n가문의 새로운 수입이 되어\\n영지는 더욱 발전할 것"
},
{
"i": 5,
"t": "\\n가문도 꽤나 커졌"
},
{
"i": 6,
"t": "\\n우리 가문을 노리고 있구나"
},
{
"i": 7,
"t": "\\n가문을 번영으로 이끌"
},
{
"i": 8,
"t": "\\n병력은 이쪽이 앞서 있"
},
{
"i": 9,
"t": "\\n당분간은 내정에 힘써야 할 듯하옵니다"
},
{
"i": 10,
"t": "\\n역직을 내려 외교 자세를 개선하여 유리하게 외교를 진행할 수 있습니다.\\n쇼군가로 플레이할 경우, 높은 위신과 역직을 활용해\\n외교를 적극적으로 펼치십시오."
},
{
"i": 11,
"t": "\\n그 땅을 가문의 중심으로 번영시키"
},
{
"i": 12,
"t": "\\n그자의 충성은 흔들리고 있"
},
{
"i": 13,
"t": "\\n그자들의 충성은 흔들리고 있"
},
{
"i": 14,
"t": "\\n피아의 전력이 팽팽한 지금\\n병력을 집중 운용하면 탈취할 수 있을 듯하"
},
{
"i": 15,
"t": "\\n세이이타이쇼군인 다이묘의 세력, 즉 쇼군가만이 실행할 수 있는 커맨드입니다.\\n다른 세력에 막부 역직을 내려 자기 세력에 대한 외교 자세를 개선할 수 있습니다.\\n\\n다만 역직을 얻은 세력은 위신이 상승하므로\\n함부로 역직을 내리지 말고 상대를 가려 가며 외교를 하십시오.\\n\\n"
},
{
"i": 16,
"t": "\\n이제 이것을 실현할 일만 남았"
},
{
"i": 17,
"t": "\\n뒷일은"
},
{
"i": 18,
"t": "\\n후임에게 인계하"
},
{
"i": 19,
"t": "\\n종속도가 높은 호족을 흡수하여\\n무장（사실 무장이 있는 경우）과 병력을 자기 세력 산하에 더합니다.\\n\\n"
},
{
"i": 20,
"t": "\\n반드시"
},
{
"i": 21,
"t": "\\n반드시 주명에 걸맞은 성과를\\n가문에 가져오"
},
{
"i": 22,
"t": "\\n반드시 무공으로 이어 보이"
},
{
"i": 23,
"t": "\\n반드시 좋은 성과를 올리"
},
{
"i": 24,
"t": "\\n기필코 토벌하리라!"
},
{
"i": 25,
"t": "\\n반드시 풍요로운 땅으로 만들어 보이"
},
{
"i": 26,
"t": "\\n필요하시면 언제든 지시를"
},
{
"i": 27,
"t": "\\n필요한 것은 다시 발령 지시를"
},
{
"i": 28,
"t": "\\n필요에 따라"
},
{
"i": 29,
"t": "\\n분하게도 방비가 증강되어 있"
},
{
"i": 30,
"t": "\\n시노비를 부리는 데는 자신이"
},
{
"i": 31,
"t": "\\n잊지 않도록 이 안을 건의해 두겠사오니\\n필요하시면"
},
{
"i": 32,
"t": "\\n충성을 다하는 것도 여기까지라"
},
{
"i": 33,
"t": "\\n충실한 종으로서 임무를 수행"
},
{
"i": 34,
"t": "\\n충성이 낮은 무장은 세력에 불이익한 행동을 할 때가 있습니다.\\n주의하십시오.\\n\\n"
},
{
"i": 35,
"t": "\\n충성이 낮은 무장을 자기 세력으로 빼내 옵니다.\\n\\n"
},
{
"i": 36,
"t": "\\n급히 수배하"
},
{
"i": 37,
"t": "\\n급히 채비를 갖추"
},
{
"i": 38,
"t": "\\n두려워할 것 없"
},
{
"i": 39,
"t": "\\n은상의"
},
{
"i": 40,
"t": "\\n보복으로 이번에는"
},
{
"i": 41,
"t": "\\n어리석은 옛 주군을 버리고 왔사옵니다\\n부디"
},
{
"i": 42,
"t": "\\n신중히"
},
{
"i": 43,
"t": "\\n성공은 틀림없"
},
{
"i": 44,
"t": "\\n처단하였소!"
},
{
"i": 45,
"t": "\\n성과에"
},
{
"i": 46,
"t": "\\n성과를 얻을 날이 머지않"
},
{
"i": 47,
"t": "\\n승산은 이쪽이 위"
},
{
"i": 48,
"t": "\\n우리 성에는 다루는 솜씨가 뛰어난 자가"
},
{
"i": 49,
"t": "\\n우리 성하를 더 나은 곳으로"
},
{
"i": 50,
"t": "\\n우리 가문의 것으로\\n삼고 싶다만…"
},
{
"i": 51,
"t": "\\n내 장기인 정무로써\\n가문 제일가는 생산의 성으로 만들"
},
{
"i": 52,
"t": "\\n내 심중에 타오르는 증오의 불길\\n그리 쉽게 꺼지리라 생각 마라"
},
{
"i": 53,
"t": "\\n내 손으로 막아 보이 "
},
{
"i": 54,
"t": "\\n제 재주를 살릴 수 있는 주군을 찾고 있었사옵니다\\n"
},
{
"i": 55,
"t": "\\n내 본분인 정무 수완\\n이 성이라면 마음껏 떨칠 수 있을 듯"
},
{
"i": 56,
"t": "\\n내 본분인 창 솜씨를 보일 수 있도록\\n통치에 힘쓸 생각"
},
{
"i": 57,
"t": "\\n내 본분인 지략을 발휘할 수 있도록\\n통치에 힘쓸 생각"
},
{
"i": 58,
"t": "\\n내 지략으로 이 성을 부려\\n전선을 보좌해 보이"
},
{
"i": 59,
"t": "\\n우리 군단은"
}
]
}
