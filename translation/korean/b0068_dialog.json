{
"cat": "dialog",
"items": [
{"i": 0, "t": "이(가)\\n이번에는 거절하도록"},
{"i": 1, "t": "이(가)\\n결코 경계를 게을리해서는"},
{"i": 2, "t": "이(가)\\n치수를 해 두었기에 큰일은"},
{"i": 3, "t": "이(가)\\n혼란에 빠지기라도 한다는 건가?"},
{"i": 4, "t": "이(가)\\n혼란에 실패…라고?"},
{"i": 5, "t": "이(가)\\n상황은 시시각각 변하는 법\\n임기응변으로 대처하여"},
{"i": 6, "t": "이(가)\\n독단으로 출진한 듯"},
{"i": 7, "t": "이(가)\\n독립했습니다"},
{"i": 8, "t": "이(가)\\n맹장・"},
{"i": 9, "t": "이(가)\\n상대해 주마"},
{"i": 10, "t": "이(가)\\n연고자를 내세워 권유하는 것은"},
{"i": 11, "t": "이(가)\\n생각할 법한 수로군"},
{"i": 12, "t": "이(가)\\n무릎을 꿇었다고 합니다.\\n이후로는 함께 걷는 사이가 되는 것입니까"},
{"i": 13, "t": "이(가)\\n함락당하다니…"},
{"i": 14, "t": "이(가)\\n걸맞을 만큼 상업이 진흥될 때까지\\n보류"},
{"i": 15, "t": "이(가)\\n평정중 발탁…납득할 수 없다!"},
{"i": 16, "t": "이(가)\\n권유하면 귀순해 줄지도…"},
{"i": 17, "t": "이(가)\\n부상을 입다니…"},
{"i": 18, "t": "이(가)\\n비용 부족으로, 계속하지 못하"},
{"i": 19, "t": "이(가)\\n부족한 것 아닌가?"},
{"i": 20, "t": "이(가)\\n목숨을 바쳐서라도 지켜 보이"},
{"i": 21, "t": "이(가)\\n신명을 바쳐 지켜내"},
{"i": 22, "t": "이(가)\\n멍에를 걷어내 줄 것입니다"},
{"i": 23, "t": "이(가)\\n얕보였다는 뜻.\\n이것만은 용서할 수 없겠군요…"},
{"i": 24, "t": "이(가)\\n쫓겨나다니…"},
{"i": 25, "t": "이(가)\\n비탈을 내리달려 진군"},
{"i": 26, "t": "이(가)\\n통하리라 생각지 마라"},
{"i": 27, "t": "이(가)\\n갈 길은 아직 절반이라 들"},
{"i": 28, "t": "이(가)\\n갈 길은 아직 절반이니\\n아직"},
{"i": 29, "t": "이(가)\\n낚였다고…！？"},
{"i": 30, "t": "이(가)\\n막을 터이니 걱정은 무용…"},
{"i": 31, "t": "이(가)\\n면회를 청하며, 찾아와"},
{"i": 32, "t": "이(가)\\n면회를 청하러 찾아왔습니다"},
{"i": 33, "t": "이(가)\\n취했다!"},
{"i": 34, "t": "이(가)\\n수급을 올릴 때입니다!"},
{"i": 35, "t": "이(가)\\n고무로 전의 상승"},
{"i": 36, "t": "이(가)…\\n…병으로 인해, 당분간은 힘을 발휘하지 못하"},
{"i": 37, "t": "이(가)…\\n그토록 아껴 주었건만"},
{"i": 38, "t": "이(가)…\\n뭐, 뒷문이 없다면 만들면 될 일"},
{"i": 39, "t": "이(가)…\\n알"},
{"i": 40, "t": "이(가)…\\n신앙의 힘은 얕볼 수 없는 법\\n"},
{"i": 41, "t": "이(가)…\\n조금 궁리가 모자라"},
{"i": 42, "t": "이(가)…\\n맞아도 팔괘, 안 맞아도 팔괘\\n걸어 보는 것도 재미있겠지"},
{"i": 43, "t": "이(가)…\\n구출하러 가야 한다!"},
{"i": 44, "t": "이(가)…\\n방심할 수 없겠군요…"},
{"i": 45, "t": "이(가)…\\n거취를, 생각해"},
{"i": 46, "t": "이(가)…！\\n"},
{"i": 47, "t": "이(가)…？\\n이 어찌, 허무한…"},
{"i": 48, "t": "이(가)…？\\n신경을 써 주시다니…"},
{"i": 49, "t": "이(가),\\n"},
{"i": 50, "t": "이(가),\\n말씀"},
{"i": 51, "t": "이(가),\\n이미 아군 장병의 채비는 갖추어져\\n"},
{"i": 52, "t": "이(가),\\n다행히, 전력은 백중하여"},
{"i": 53, "t": "이(가),\\n적 쪽에 이름난 장수는"},
{"i": 54, "t": "이(가),\\n적진에 지장・"},
{"i": 55, "t": "이(가), 수락할지는\\n부딪쳐 봐야겠군…"},
{"i": 56, "t": "이(가), 이런 곳까지！\\n죽음을 두려워 않는 사나운 무사들에\\n어찌 맞서"},
{"i": 57, "t": "이(가), 이 성으로…\\n서둘러 기병에 대한 대비를 갖추어"},
{"i": 58, "t": "이(가), 대책을 세운 땅은\\n화를 면했다"},
{"i": 59, "t": "이(가), 총무사 위반을 추궁당한 것은\\n<ESC>CB호조<ESC>CZ만이 아니다. <ESC>CC오슈<ESC>CZ의 풍운아 <ESC>CA다테 마사무네<ESC>CZ도\\n<ESC>CA히데요시<ESC>CZ에게 혐의를 받고 있었던 것이다."}
]
}
