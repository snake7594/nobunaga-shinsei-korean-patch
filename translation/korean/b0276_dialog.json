{
"items": [
{"i": 0, "t": "공격에 대비해\\n크게 계략을 꾸며 두겠노라"},
{"i": 1, "t": "공격에 땅굴 공격을 쓰자\\n손쉽게 성을 함락할 수 있으리라"},
{"i": 2, "t": "공격으로 돌아가라\\n내 계략을 방해하게 두지 않겠다"},
{"i": 3, "t": "공격에만 마음 쓰지 말고\\n"},
{"i": 4, "t": "공격의 승기는 멀다\\n헛되이 피해를 키우기 전에\\n철수를 진언하오"},
{"i": 5, "t": "공격의 기세\\n이 정도로는 막을 수 없다"},
{"i": 6, "t": "공격의 호기\\n백성을 선동해 당가에 동조시키면\\n적령 진군도 수월해지느니"},
{"i": 7, "t": "공격의 밀약\\n부디 어기시는 일 없도록"},
{"i": 8, "t": "공격의 성패는 반반…\\n전력이 호각이라 무장과 지휘에 따라\\n승패가 갈릴 것이다"},
{"i": 9, "t": "공격의 때가 왔다\\n한시라도 빨리 싸울 채비를 갖추어라!"},
{"i": 10, "t": "공격 중에 미안하네만\\n"},
{"i": 11, "t": "공격 동안 성을 지킬 자로서\\n"},
{"i": 12, "t": "공격의 약조\\n어기는 일 없도록"},
{"i": 13, "t": "공격의 약속\\n잊어서는 아니 되오"},
{"i": 14, "t": "공격의 장애물은 길목의 요새…\\n허나 수비병만 배반케 하면\\n요새도 한낱 장식일 뿐"},
{"i": 15, "t": "공격은\\n여기까지다… 물러나라"},
{"i": 16, "t": "공격은\\n중단해야 하오"},
{"i": 17, "t": "공격은\\n그만두고 퇴각하라"},
{"i": 18, "t": "공격은\\n이룰 수 없다. 철수한다"},
{"i": 19, "t": "공격은\\n무리다. 철수할 수밖에 없어"},
{"i": 20, "t": "공격은\\n포기하고 철수합시다"},
{"i": 21, "t": "공격은\\n포기하고 물러나자…"},
{"i": 22, "t": "공격은\\n포기한다. 철수하라"},
{"i": 23, "t": "공격은 아직 나중 일이니\\n말이다"},
{"i": 24, "t": "공격은 아직 한동안\\n먼 듯하니, 지금은"},
{"i": 25, "t": "공격은 중지\\n다음 기회도 있으리라"},
{"i": 26, "t": "공격은 중지\\n병사를 성에서 쉬게 해야겠다"},
{"i": 27, "t": "공격은 중지\\n성에서 병사를 쉬게 하라"},
{"i": 28, "t": "공격은 중지\\n포기하고 돌아가겠다… 이번에는"},
{"i": 29, "t": "공격은 중지\\n물러나라… 병량이 아깝다"},
{"i": 30, "t": "공격은 끝이다\\n"},
{"i": 31, "t": "공격은 헛수고니라\\n"},
{"i": 32, "t": "공격은 시기상조인 듯\\n여기서는"},
{"i": 33, "t": "공격은 무의미\\n"},
{"i": 34, "t": "공격은 좋소만\\n적은 아군 못지않게 강하다 하니\\n타가에 원군을 청하시오"},
{"i": 35, "t": "공격은 긴요하나\\n"},
{"i": 36, "t": "공격도\\n염두에 두어야겠구나"},
{"i": 37, "t": "공격도 중요하나\\n"},
{"i": 38, "t": "공격하든 지키든\\n요새는 확보하는 것이 좋을 듯하오"},
{"i": 39, "t": "공격해야 하오\\n성하의 군을 함락해 발밑을 무너뜨리면\\n필시 낙성시킬 수 있을 것이오"},
{"i": 40, "t": "공격할 것도 없다\\n에워싸라!"},
{"i": 41, "t": "공격하기 전에 주변을\\n장악해 두어야겠군"},
{"i": 42, "t": "공격을\\n생각하신다면 부디"},
{"i": 43, "t": "공격을\\n포기하고 물러나기로 하자"},
{"i": 44, "t": "공격을 우선하겠소\\n약병이라도 공을 세울 수 있을 것이오"},
{"i": 45, "t": "공격을 삼가는 지금\\n대비책으로"},
{"i": 46, "t": "공격을 유리하게 하기 위해\\n"},
{"i": 47, "t": "쳐들어갈 길에 비해\\n부대 수가 너무 많은 방면이"},
{"i": 48, "t": "빼앗았다\\n성으로 돌아가자고"},
{"i": 49, "t": "공격로를 확보해\\n공성에 임하리라"},
{"i": 50, "t": "공격 측 아군 세력에는 방어를 의뢰할 수 없습니다"},
{"i": 51, "t": "공성 전에\\n주위에 부대를 배치해야 하오"},
{"i": 52, "t": "공성전에는 희생이 크다… 허나\\n미리 적 성의 방비를 약화해\\n둘 수 있다면…"},
{"i": 53, "t": "공성전을 생각하신다면 군을 내기\\n전에 취해야 할 계책이"},
{"i": 54, "t": "공격이 격렬하다…\\n고지를 빼앗으러 가겠소"},
{"i": 55, "t": "공격에 즈음해\\n주변을 평정한 뒤 공격하면\\n수월해질 것이오"},
{"i": 56, "t": "공격의 고삐를 늦추어서는\\n아니 되오!"},
{"i": 57, "t": "공격은\\n중단이다, 철수하라!"},
{"i": 58, "t": "공격을\\n마무리하고 철수한다"},
{"i": 59, "t": "공략\\n성공하겠습니다만…"}
]
}
